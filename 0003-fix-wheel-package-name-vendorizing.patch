From f0209e01e334f01761a7324eef0faed007d87a51 Mon Sep 17 00:00:00 2001
From: Stefan Agner <stefan@agner.ch>
Date: Fri, 7 Nov 2025 17:48:03 +0100
Subject: [PATCH] fix wheel package name vendorizing

Vendorizing the wheel package name broke with the rename from chip to
matter in #40751. This fixes vendorizing the package name.
---
 src/controller/python/BUILD.gn | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/controller/python/BUILD.gn b/src/controller/python/BUILD.gn
index e644ee811a..dc487894c4 100644
--- a/src/controller/python/BUILD.gn
+++ b/src/controller/python/BUILD.gn
@@ -339,7 +339,7 @@ matter_python_wheel_action("matter-core") {
     "deprecation",
     "ecdsa",
     "ipdb",
-    "matter-clusters",
+    "${chip_python_package_prefix}-clusters",
     "pyyaml",
     "rich",
   ]
@@ -449,7 +449,7 @@ matter_python_wheel_action("matter-repl") {
     "pyobjc-framework-corebluetooth ; sys_platform==\"darwin\"",
     "dbus-python==1.2.18 ; sys_platform==\"linux\"",
     "pygobject==3.50.0 ; sys_platform==\"linux\"",
-    "matter-core",
+    "${chip_python_package_prefix}-core",
   ]
 
   py_package_name = "${chip_python_package_prefix}-repl"
-- 
2.53.0

